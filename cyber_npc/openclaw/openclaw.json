{
	"agents": {
		"defaults": {
			"model": {
				"primary": "ollama/qwen3.5:cloud",
				"fallbacks": [
					"ollama/kimi-k2.6:cloud"
				]
			},
			"workspace": "/home/node/.openclaw/workspace",
		}
	},
	"channels": {
		"matrix": {
			"network": {
				"dangerouslyAllowPrivateNetwork": true
			},
			"enabled": true,
			"homeserver": "https://${MATRIX_HOSTNAME}",
			"userId": "${MARTIX_USERNAME}",
			"password": "${MATRIX_PASSWORD}",
			"dm": {
				"policy": "allowlist",
				"allowFrom": [
					"@{MATRIX_ADMIN}:${MATRIX_HOSTNAME}"
				]
			},
			"encryption": true,
			"autoJoin": "always",
		}
	},
	"commands": {
		"native": "auto",
		"nativeSkills": "auto",
		"ownerDisplay": "raw",
		"restart": true
	},
	"discovery": {
		"mdns": {
			"mode": "off"
		}
	},
	"gateway": {
		"bind": "lan",
		"mode": "local",
		"port": 18789,
		"tailscale": {
			"mode": "off",
			"resetOnExit": false
		}
	},
	"models": {
		"providers": {
			
		}
	},
	"plugins": {
		"allow": [
			"matrix"
		],
		"entries": {
			"matrix": {
				"enabled": true
			}
		}
	},
	"session": {
		"dmScope": "per-channel-peer"
	},
	"tools": {
		"web": {
			"search": {
				"provider": "ollama"
			}
		}
	}
}
